{
  "name": "a4-resume-template",
  "version": "1.0.0",
  "description": "Printable A4 resume template with SCSS theming and a11y-compliant color palette",
  "type": "module",
  "scripts": {
    "build:css": "sass styles/theme.scss styles/theme.css --no-source-map",
    "dev": "serve . -l 3000",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "keywords": [
    "resume",
    "cv",
    "a4",
    "printable",
    "template",
    "a11y"
  ],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "sass": "^1.100.0",
    "serve": "^14.2.6"
  }
}
