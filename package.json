{
  "name": "a4-resume-template",
  "version": "1.0.0",
  "description": "Printable A4 resume/CV template with SCSS theming, automatic color palette generation, WCAG AA a11y compliance, Playwright integration tests, and AI agent skill",
  "repository": {
    "type": "git",
    "url": "https://github.com/tychenjiajun/a4-resume-template.git"
  },
  "type": "module",
  "scripts": {
    "build:css": "sass styles/theme.scss styles/theme.css --no-source-map",
    "dev": "serve . -l 3000",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug"
  },
  "keywords": [
    "resume",
    "cv",
    "a4",
    "printable",
    "template",
    "a11y",
    "wcag",
    "scss",
    "playwright",
    "accessibility",
    "agent-skill",
    "ai-agent"
  ],
  "author": "Jiajun Chen <tychenjiajun@live.cn> (https://github.com/tychenjiajun)",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "sass": "^1.100.0",
    "serve": "^14.2.6"
  }
}
